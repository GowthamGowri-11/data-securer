# Database Configuration - MongoDB Atlas
# Get your connection string from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/database?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://admin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/tamper-detection?retryWrites=true&w=majority"

# Blockchain Configuration - Ethereum Sepolia Testnet
BLOCKCHAIN_RPC_URL="https://rpc.sepolia.org"
SEPOLIA_RPC_URL="https://rpc.sepolia.org"
BLOCKCHAIN_NETWORK="sepolia"

# Smart Contract Address (Will be updated after deployment)
CONTRACT_ADDRESS=""

# Wallet Private Key
PRIVATE_KEY="0x8dc51199266b4d0e54434b84d8927755016f89e2171b9a37b7d39c0bb378a502"

# Encryption Secret Key
AES_SECRET_KEY="blockchain-tamper-detection-secret-key-2026"

# Application Mode
NODE_ENV="development"

# Google OAuth Configuration
# Get your credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"